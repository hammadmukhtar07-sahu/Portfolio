# portfolio/.env.example
# Copy this file to .env and fill in your values
# For Railway: set these as environment variables in the Railway dashboard (NOT in this file)

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
CLIENT_URL=https://your-portfolio.vercel.app

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/portfolio?retryWrites=true&w=majority

# ─── JWT (Admin auth) ─────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ─── Resend Email (https://resend.com/api-keys) ───────────────────────────────
# NEVER commit your real key — set it directly in Railway environment variables
RESEND_API_KEY=re_your_api_key_here
EMAIL_TO=hammadmukhtar128@gmail.com
